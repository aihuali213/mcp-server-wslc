  "repository": {
    "type": "git",
    "url": "git+https://github.com/aihuali213/mcp-server-wslc.git"
  },
  "bugs": {
    "url": "https://github.com/aihuali213/mcp-server-wslc/issues"
  },
  "homepage": "https://github.com/aihuali213/mcp-server-wslc#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
