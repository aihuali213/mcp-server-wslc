{
  "name": "mcp-server-wslc",
  "version": "1.0.3",
  "description": "MCP server for WSL container management via wslc CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-wslc": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
